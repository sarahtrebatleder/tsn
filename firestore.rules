// ─────────────────────────────────────────────────────────────────────────────
// firestore.rules — TSN Restaurant Tracker
//
// SETUP INSTRUCTIONS:
//   1. Replace "YOUR_UID_HERE" with your real Firebase UID.
//      Find your UID in the Firebase console → Authentication → Users.
//   2. Deploy these rules in the Firebase console:
//      Firestore Database → Rules → paste and publish.
//      OR use the Firebase CLI: firebase deploy --only firestore:rules
//
// IMPORTANT: NEVER commit your real UID to version control.
//   This file uses the same placeholder pattern as config.example.js.
//   The real UID must be entered manually in the Firebase console or
//   in your local firebase deploy workflow, and should not be committed here.
// ─────────────────────────────────────────────────────────────────────────────

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /restaurants/{docId} {
      // Only the single allowed user may read or write any restaurant document.
      allow read, write: if request.auth != null
                         && request.auth.uid == "YOUR_UID_HERE";
    }

    // Deny everything else by default.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
